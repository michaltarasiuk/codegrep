{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "$/*": ["src/*"]
    },
    "moduleResolution": "node",
    "module": "ES2022",
    "erasableSyntaxOnly": true,
    "target": "ES2021",
    "moduleDetection": "force"
  }
}
