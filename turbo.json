{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "WEB_URL",
    "PUBLIC_WEB_URL",
    "API_URL",
    "DATABASE_URL",
    "GROQ_API_KEY",
    "BETTER_AUTH_BASE_URL",
    "BETTER_AUTH_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "persistent": true
    },
    "type:check": {}
  }
}
