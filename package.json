{
  "name": "githubgrep",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "check": "bun run format:check && ultracite check && turbo run typecheck",
    "fix": "prettier --write . && ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.4.1",
    "lefthook": "^2.1.1",
    "turbo": "^2.3.3",
    "typescript": "5.9.2",
    "ultracite": "7.2.1"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*"
  ]
}
